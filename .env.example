# Anthropic API Key (för Claude AI)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Admin Panel Configuration
# To change admin password, generate SHA-256 hash:
# Example: echo -n "your_password" | sha256sum
# Default password: "admin123"
ADMIN_PASSWORD_HASH=240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9

# Alternativt: OpenAI API Key
OPENAI_API_KEY=sk-xxxxx

# Database URL (optional - använder in-memory som default)
DATABASE_URL=sqlite:///./assessment.db

# CORS Origins (komma-separerade)
ALLOWED_ORIGINS=http://localhost:3000,https://your-lovable-app.lovable.app

# Environment
ENVIRONMENT=development
