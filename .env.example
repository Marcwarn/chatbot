# Anthropic API Key (för Claude AI)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Alternativt: OpenAI API Key
OPENAI_API_KEY=sk-xxxxx

# Database URL (optional - använder in-memory som default)
DATABASE_URL=sqlite:///./assessment.db

# CORS Origins (komma-separerade)
ALLOWED_ORIGINS=http://localhost:3000,https://your-lovable-app.lovable.app

# Environment
ENVIRONMENT=development
