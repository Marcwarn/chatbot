# Staging Environment Configuration
# Copy to Vercel environment variables for staging deployment

# Environment
ENVIRONMENT=staging
DEBUG=true

# Database - Staging Database (separate from production)
DATABASE_URL=postgresql://staging-user:staging-pass@staging-host.postgres.database.azure.com:5432/staging_db

# Anthropic API Key (can use same as production or separate)
ANTHROPIC_API_KEY=sk-ant-staging-xxxxx

# Admin Panel Configuration
# Generate new hash: echo -n "your_password" | sha256sum
ADMIN_PASSWORD_HASH=staging-password-hash-here
ADMIN_API_KEY=staging-secure-api-key-here

# CORS Origins - Staging domain
ALLOWED_ORIGINS=https://persona-assessment-staging.vercel.app,http://localhost:3000

# API URLs
NEXT_PUBLIC_API_URL=https://persona-assessment-staging.vercel.app/api

# Monitoring - Staging Sentry project
SENTRY_DSN=https://xxx@sentry.io/staging-project-id
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=1.0

# Rate Limiting - More relaxed for testing
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Cost Tracking - Separate budget
MONTHLY_COST_BUDGET=50
COST_ALERT_THRESHOLD=0.8

# Feature Flags - Can enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_DEBUG_ENDPOINTS=true

# Session Configuration
SESSION_TIMEOUT_MINUTES=60

# Cache Configuration
CACHE_TTL_SECONDS=300
ENABLE_CACHE=true

# Email Configuration (optional for staging)
SMTP_HOST=smtp.staging.example.com
SMTP_PORT=587
SMTP_USER=staging@example.com
SMTP_FROM=noreply-staging@example.com

# Logging
LOG_LEVEL=DEBUG
ENABLE_REQUEST_LOGGING=true
