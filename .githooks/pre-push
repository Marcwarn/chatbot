#!/bin/bash
#
# Pre-push Hook - Final Security Validation
# Last line of defense before code reaches production
#

set -e

echo "🚀 Running pre-push security validation..."

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

# =============================================================================
# CHECK 1: Environment Variables Check
# =============================================================================
echo "🔧 [1/5] Checking for .env file in staging area..."

if git diff --cached --name-only | grep -E "^\.env$|\.env\.production$"; then
    echo -e "${RED}❌ CRITICAL: .env file is staged for commit${NC}"
    echo "   NEVER commit .env files (contains secrets)"
    echo "   Run: git reset HEAD .env"
    ERRORS=$((ERRORS + 1))
fi

# =============================================================================
# CHECK 2: Large Files (potential data leaks)
# =============================================================================
echo "📦 [2/5] Checking for large files..."

LARGE_FILES=$(git diff --cached --name-only | xargs -I {} stat -f%z {} 2>/dev/null | awk '$1 > 1048576 {print}' || true)

if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠️  WARNING: Large files detected (>1MB)${NC}"
    echo "   Ensure no database dumps or sensitive data files are being pushed"
    WARNINGS=$((WARNINGS + 1))
fi

# =============================================================================
# CHECK 3: Dependency Vulnerabilities
# =============================================================================
echo "🔍 [3/5] Checking for dependency vulnerabilities..."

if [ -f "requirements.txt" ]; then
    # Check if pip-audit is installed
    if command -v pip-audit > /dev/null 2>&1; then
        if ! pip-audit --requirement requirements.txt > /dev/null 2>&1; then
            echo -e "${YELLOW}⚠️  WARNING: Vulnerabilities found in dependencies${NC}"
            echo "   Run: pip-audit --requirement requirements.txt"
            echo "   Consider updating vulnerable packages"
            WARNINGS=$((WARNINGS + 1))
        fi
    else
        echo "   ℹ️  Skipping (pip-audit not installed)"
        echo "   Install with: pip install pip-audit"
    fi
fi

# =============================================================================
# CHECK 4: Test Coverage for Security-Critical Code
# =============================================================================
echo "🧪 [4/5] Checking for security tests..."

if [ -d "tests" ]; then
    if [ ! -f "tests/test_security.py" ]; then
        echo -e "${YELLOW}⚠️  WARNING: No security tests found${NC}"
        echo "   Consider creating tests/test_security.py"
        WARNINGS=$((WARNINGS + 1))
    else
        echo "   ✅ Security tests present"
    fi
fi

# =============================================================================
# CHECK 5: Git Secrets Scan (if available)
# =============================================================================
echo "🔐 [5/5] Scanning for secrets in commit history..."

# Check if git-secrets is installed
if command -v git-secrets > /dev/null 2>&1; then
    if ! git secrets --scan -r; then
        echo -e "${RED}❌ CRITICAL: Secrets detected in repository${NC}"
        ERRORS=$((ERRORS + 1))
    fi
else
    echo "   ℹ️  Skipping (git-secrets not installed)"
    echo "   Install with: brew install git-secrets (macOS) or see https://github.com/awslabs/git-secrets"
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}❌ PUSH BLOCKED: $ERRORS critical security issue(s) found${NC}"
    echo ""
    echo "Fix the issues above before pushing."
    echo "See LESSONS_LEARNED.md for guidance."
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠️  $WARNINGS warning(s) found${NC}"
    echo ""
    echo "Consider fixing these warnings before pushing to production."
    echo -e "${GREEN}✅ Pre-push checks passed (with warnings)${NC}"
    exit 0
else
    echo -e "${GREEN}✅ All pre-push security checks passed!${NC}"
    exit 0
fi
