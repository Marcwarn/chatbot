#!/bin/bash
#
# Pre-commit Hook - Security Validation
# Prevents committing code with common security vulnerabilities
#
# Installation:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#

set -e

echo "🔒 Running security pre-commit checks..."

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

ERRORS=0
WARNINGS=0

# Get list of staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY_FILES" ]; then
    echo "✅ No Python files to check"
    exit 0
fi

echo "📁 Checking files: $STAGED_PY_FILES"
echo ""

# =============================================================================
# CHECK 1: Hardcoded Passwords/Keys/Tokens
# =============================================================================
echo "🔑 [1/7] Checking for hardcoded secrets..."

SECRET_PATTERNS=(
    "password\s*=\s*['\"][^'\"]+['\"]"
    "api[_-]?key\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "token\s*=\s*['\"][^'\"]+['\"]"
    "CHANGE_ME"
    "TODO.*PRODUCTION"
    "FIXME.*SECURITY"
    "['\"][0-9a-f]{32,}['\"]"  # Long hex strings (potential API keys)
    "sk-[a-zA-Z0-9]{32,}"      # OpenAI/Anthropic API keys
)

for pattern in "${SECRET_PATTERNS[@]}"; do
    for file in $STAGED_PY_FILES; do
        if grep -inE "$pattern" "$file" | grep -v "os.getenv" | grep -v "# Example:" | grep -v "# ❌ NEVER" | grep -v "LESSONS_LEARNED"; then
            echo -e "${RED}❌ CRITICAL: Potential hardcoded secret found in $file${NC}"
            echo "   Pattern: $pattern"
            ERRORS=$((ERRORS + 1))
        fi
    done
done

# =============================================================================
# CHECK 2: Weak Password Hashing (SHA-256, MD5, SHA-1)
# =============================================================================
echo "🔐 [2/7] Checking for weak password hashing..."

WEAK_HASH_PATTERNS=(
    "hashlib\.sha256.*password"
    "hashlib\.sha1.*password"
    "hashlib\.md5.*password"
    "def hash_password.*sha256"
    "def hash_password.*sha1"
    "def hash_password.*md5"
)

for pattern in "${WEAK_HASH_PATTERNS[@]}"; do
    for file in $STAGED_PY_FILES; do
        if grep -inE "$pattern" "$file" | grep -v "# ❌ NEVER" | grep -v "LESSONS_LEARNED"; then
            echo -e "${RED}❌ CRITICAL: Weak password hashing detected in $file${NC}"
            echo "   Use bcrypt instead of SHA-256/MD5/SHA-1"
            echo "   Pattern: $pattern"
            ERRORS=$((ERRORS + 1))
        fi
    done
done

# Check if bcrypt is used for password hashing
for file in $STAGED_PY_FILES; do
    if grep -q "def hash_password" "$file" || grep -q "def verify_password" "$file"; then
        if ! grep -q "bcrypt" "$file"; then
            echo -e "${YELLOW}⚠️  WARNING: Password functions found but not using bcrypt in $file${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# =============================================================================
# CHECK 3: CORS Wildcard
# =============================================================================
echo "🌐 [3/7] Checking for CORS wildcard configuration..."

if echo "$STAGED_PY_FILES" | xargs grep -l "CORSMiddleware" > /dev/null 2>&1; then
    for file in $STAGED_PY_FILES; do
        if grep -n "allow_origins.*\[.*\"\*\".*\]" "$file" | grep -v "# ❌ NEVER"; then
            echo -e "${RED}❌ CRITICAL: CORS wildcard detected in $file${NC}"
            echo "   Use explicit origin whitelist instead of ['*']"
            ERRORS=$((ERRORS + 1))
        fi
    done
fi

# =============================================================================
# CHECK 4: Timing Attack Vulnerabilities
# =============================================================================
echo "⏱️  [4/7] Checking for timing attack vulnerabilities..."

TIMING_PATTERNS=(
    "password.*==.*password"
    "password.*!=.*password"
    "token.*==.*token"
    "token.*!=.*token"
    "api_key.*==.*api_key"
    "secret.*==.*secret"
)

for pattern in "${TIMING_PATTERNS[@]}"; do
    for file in $STAGED_PY_FILES; do
        if grep -inE "$pattern" "$file" | grep -v "secrets.compare_digest" | grep -v "# ❌ NEVER" | grep -v "LESSONS_LEARNED"; then
            echo -e "${RED}❌ CRITICAL: Timing attack vulnerability in $file${NC}"
            echo "   Use secrets.compare_digest() for security-critical comparisons"
            echo "   Pattern: $pattern"
            ERRORS=$((ERRORS + 1))
        fi
    done
done

# =============================================================================
# CHECK 5: SQL Injection Patterns
# =============================================================================
echo "💉 [5/7] Checking for SQL injection vulnerabilities..."

SQL_INJECTION_PATTERNS=(
    "execute\(.*f['\"].*{.*}.*['\"]"  # f-strings in SQL
    "execute\(.*%.*%"                  # % formatting in SQL
    "execute\(.*\+.*\)"                # String concatenation in SQL
    "SELECT.*FROM.*{.*}"               # Direct string interpolation
    "INSERT.*INTO.*{.*}"
    "UPDATE.*SET.*{.*}"
    "DELETE.*FROM.*{.*}"
)

for pattern in "${SQL_INJECTION_PATTERNS[@]}"; do
    for file in $STAGED_PY_FILES; do
        if grep -inE "$pattern" "$file" | grep -v "# ❌ NEVER" | grep -v "LESSONS_LEARNED"; then
            echo -e "${RED}❌ CRITICAL: Potential SQL injection in $file${NC}"
            echo "   Use parameterized queries or ORM instead"
            echo "   Pattern: $pattern"
            ERRORS=$((ERRORS + 1))
        fi
    done
done

# =============================================================================
# CHECK 6: Input Validation
# =============================================================================
echo "✏️  [6/7] Checking for missing input validation..."

for file in $STAGED_PY_FILES; do
    # Check if file has route definitions
    if grep -q "@router\.\(get\|post\|put\|delete\)" "$file" || grep -q "@app\.\(get\|post\|put\|delete\)" "$file"; then
        # Check for path parameters without validation
        if grep -E "async def.*\(.*:\s*str\)" "$file" | grep -v "Field\(" | grep -v "Path\(" | grep -v "Query\(" > /dev/null; then
            echo -e "${YELLOW}⚠️  WARNING: Path parameter without validation in $file${NC}"
            echo "   Consider adding Field() or Path() validation with regex pattern"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# =============================================================================
# CHECK 7: Authentication & Authorization
# =============================================================================
echo "🔓 [7/7] Checking for missing authentication..."

for file in $STAGED_PY_FILES; do
    # Check for endpoints that might need authentication
    if grep -E "@router\.(delete|put)" "$file" > /dev/null; then
        # Check if Depends() is used (FastAPI dependency injection for auth)
        if ! grep -q "Depends(" "$file"; then
            echo -e "${YELLOW}⚠️  WARNING: DELETE/PUT endpoint without Depends() in $file${NC}"
            echo "   Consider adding authentication with Depends(verify_token)"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi

    # Check for GDPR endpoints without auth
    if grep -q "/gdpr/" "$file"; then
        if ! grep -q "Depends(verify_admin_token)" "$file" && ! grep -q "Depends(verify_token)" "$file"; then
            echo -e "${YELLOW}⚠️  WARNING: GDPR endpoint without authentication in $file${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# =============================================================================
# Summary
# =============================================================================
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}❌ COMMIT BLOCKED: $ERRORS critical security issue(s) found${NC}"
    echo ""
    echo "Fix the issues above before committing."
    echo "See LESSONS_LEARNED.md for guidance."
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠️  $WARNINGS warning(s) found${NC}"
    echo ""
    echo "Consider fixing these warnings, but commit is allowed."
    echo -e "${GREEN}✅ Security checks passed${NC}"
    exit 0
else
    echo -e "${GREEN}✅ All security checks passed!${NC}"
    exit 0
fi
