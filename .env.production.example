# Production Environment Configuration
# Copy to Vercel environment variables for production deployment

# Environment
ENVIRONMENT=production
DEBUG=false

# Database - Production Database
DATABASE_URL=postgresql://prod-user:prod-pass@prod-host.postgres.database.azure.com:5432/prod_db

# Anthropic API Key (production key)
ANTHROPIC_API_KEY=sk-ant-prod-xxxxx

# Admin Panel Configuration
# Generate new hash: echo -n "your_secure_password" | sha256sum
ADMIN_PASSWORD_HASH=production-password-hash-here
ADMIN_API_KEY=production-secure-api-key-here

# CORS Origins - Production domain only
ALLOWED_ORIGINS=https://persona-assessment.vercel.app

# API URLs
NEXT_PUBLIC_API_URL=https://persona-assessment.vercel.app/api

# Monitoring - Production Sentry project
SENTRY_DSN=https://xxx@sentry.io/production-project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate Limiting - Strict production limits
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=300

# Cost Tracking - Production budget
MONTHLY_COST_BUDGET=200
COST_ALERT_THRESHOLD=0.9

# Feature Flags - Production settings
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_DEBUG_ENDPOINTS=false

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Cache Configuration
CACHE_TTL_SECONDS=600
ENABLE_CACHE=true

# Email Configuration
SMTP_HOST=smtp.production.example.com
SMTP_PORT=587
SMTP_USER=production@example.com
SMTP_FROM=noreply@example.com

# Logging
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true

# Security
FORCE_HTTPS=true
ENABLE_CSRF_PROTECTION=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# Performance
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
MAX_REQUEST_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=10

# Backup Configuration
ENABLE_AUTO_BACKUP=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
